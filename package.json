{
  "name": "pact",
  "version": "0.1.0",
  "private": true,
  "description": "Provable USDC streaming for autonomous agents on Arc",
  "workspaces": [
    "shared",
    "contracts",
    "services/api"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev -w @pact/api",
    "start": "npm run start -w @pact/api",
    "demo:seed": "npm run demo:seed -w @pact/api",
    "demo:run": "npm run demo:run -w @pact/api",
    "contracts:compile": "npm run build -w @pact/contracts",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
