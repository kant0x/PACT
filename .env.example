# Local product
PORT=4100
WEB_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4100
VITE_API_TOKEN=
VITE_PACT_MODE=demo
VITE_AUTO_SEED_DEMO=true
PACT_DB_PATH=data/pact.sqlite
# Optional: required only for the PostgreSQL repository/indexer path.
# Store the real value in your server secret manager; never commit it.
DATABASE_URL=
PACT_AUTH_TOKEN=
PACT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PACT_RATE_LIMIT_WINDOW_MS=60000
PACT_RATE_LIMIT_MAX=300
PACT_ENABLE_DEMO_ENDPOINTS=true
PACT_JSON_LIMIT=64kb
PACT_EVIDENCE_MAX_CHARS=20000
PACT_HUMAN_REVIEWER_ID=authorized-human-reviewer

# Training Ground v2. The local example uses the explicit deterministic rubric.
# The production template overrides it with OpenAI and requires a private
# generator secret of at least 32 random bytes.
PACT_ARENA_GENERATOR_SECRET=
ARENA_JUDGE_PROVIDER=deterministic
ARENA_JUDGE_MODEL=gpt-4o-mini
ARENA_JUDGE_TEACHER_MODEL=gpt-5.6-terra
ARENA_JUDGE_TIMEOUT_MS=20000
ARENA_JUDGE_MAX_OUTPUT_TOKENS=300
PACT_ARENA_RUNNER_IMAGE=node:22-bookworm-slim
PACT_ARENA_RUNNER_TIMEOUT_MS=8000

# Runtime adapter: demo (works locally) or arc (requires the credentials below)
PACT_MODE=demo
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
EXPECTED_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=
STREAMING_VAULT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
# Optional on Arc deployment: empty means deploy PACT's controlled testnet module.
DISPUTE_MODULE_ADDRESS=
COLLATERAL_TIMEOUT_SECONDS=86400
AUTHORIZED_OPERATOR_ADDRESS=

# Training Ground Platform Points (non-transferable; optional in demo mode).
# After deploying contracts, set PLATFORM_POINTS_ADDRESS to the recorded
# address. The awarder key must belong to an authorized awarder on that
# contract; never expose it to the frontend or commit it.
PLATFORM_POINTS_ADDRESS=
PLATFORM_POINTS_AWARDER_PRIVATE_KEY=
PLATFORM_POINTS_AWARDER_ADDRESS=
PLATFORM_POINTS_RPC_URL=https://rpc.testnet.arc.network
PLATFORM_POINTS_CHAIN_ID=5042002
PLATFORM_POINTS_REQUIRED=false

# Circle Agent Stack (only required in arc mode)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_SET_NAME=PACT Agent Wallets
CIRCLE_GATEWAY_API_URL=
CIRCLE_AGENT_WALLET_ADDRESS=
CIRCLE_POLICY_CHAIN=BASE
CIRCLE_POLICY_PER_TX=25
CIRCLE_POLICY_DAILY=100
CIRCLE_POLICY_WEEKLY=500
CIRCLE_POLICY_MONTHLY=1500
GATEWAY_PRIVATE_KEY=
NANOPAYMENT_URL=

# Optional real x402 metering for an external runtime/API resource.
# PACT work-order escrow remains StreamingVault; this rail only charges
# /api/runtime/paid-capability through Circle Gateway.
X402_SELLER_ADDRESS=
X402_NETWORK=eip155:5042002
X402_RUNTIME_PRICE=$0.01
X402_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# Circle Gas Station / Paymaster guard for one sponsored first SCA operation.
# Keep disabled until the Console policy, SCA wallet UUID, and deployed vault are verified.
CIRCLE_PAYMASTER_ENABLED=false
CIRCLE_GAS_STATION_POLICY_CONFIRMED=false
CIRCLE_PAYMASTER_CHAIN=ARC-TESTNET
CIRCLE_PAYMASTER_ALLOWED_CHAINS=ARC-TESTNET
CIRCLE_PAYMASTER_ALLOWED_CONTRACTS=
CIRCLE_PAYMASTER_ALLOWED_WALLET_IDS=
CIRCLE_PAYMASTER_MAX_OPERATION_USDC=25
CIRCLE_PAYMASTER_FEE_LEVEL=MEDIUM
CIRCLE_PAYMASTER_DB_PATH=data/paymaster.sqlite

# Optional real arbitration. "council" runs three independent judge roles and requires a 2/3 quorum.
OPENAI_API_KEY=
ARBITRATOR_PROVIDER=deterministic
ARBITRATOR_MODEL=gpt-5.6-terra
# Fallback applies only to the single "openai" provider. Council provider outages fail closed;
# a valid 1/1/1 council split is persisted as NEEDS_HUMAN_REVIEW.
ARBITRATOR_FALLBACK=deterministic
ARBITRATOR_TIMEOUT_MS=15000

# Live marketplace agent runtime. Production requires OPENAI_API_KEY.
AGENT_MODEL=gpt-5.6-terra
# Optional real runtime validators. Tools remain unavailable unless the matching
# endpoint is configured; PACT never emits a simulated success receipt.
PACT_SOURCE_VERIFIER_URL=
PACT_CODE_VALIDATOR_URL=
PACT_RUNTIME_VALIDATOR_TOKEN=
PACT_RUNTIME_VALIDATOR_TIMEOUT_MS=20000
PACT_REQUIRE_ARENA_SIGNATURES=false

# Persistent Training Ground agent worker. Store the private key in the hosting
# provider's secret manager; never commit a real value.
PACT_API_URL=http://localhost:4100
PACT_ARENA_AGENT_NAME=PACT Research Agent
PACT_ARENA_AGENT_ADDRESS=
PACT_ARENA_AGENT_PRIVATE_KEY=
PACT_ARENA_POLL_INTERVAL_MS=30000
