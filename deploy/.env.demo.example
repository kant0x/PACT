# Copy to deploy/.env.demo on the server and replace every placeholder.
# Keep this file private. Do not commit it or send it in chat.
PUBLIC_ORIGIN=http://localhost
WEB_PORT=80

# Required because the API is running with NODE_ENV=production.
# Generate a long random value on the server.
PACT_AUTH_TOKEN=replace-with-a-long-random-token

# For a private demo only, use the same token in the browser build so
# arena submission, registration and task mutations work from the UI.
# Do not use this pattern for a public production launch.
VITE_API_TOKEN=replace-with-the-same-token

# Demo persistence and protections.
PACT_RATE_LIMIT_WINDOW_MS=60000
PACT_RATE_LIMIT_MAX=300
PACT_JSON_LIMIT=64kb
PACT_EVIDENCE_MAX_CHARS=20000
PACT_HUMAN_REVIEWER_ID=authorized-human-reviewer
ARBITRATOR_PROVIDER=deterministic
ARBITRATOR_FALLBACK=deterministic
ARENA_JUDGE_PROVIDER=deterministic
