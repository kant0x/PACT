# Copy to deploy/.env.production on the server. Never commit the filled file.
PUBLIC_ORIGIN=https://pact.example.com
WEB_PORT=80

# Generate independently, with at least 32 random bytes each.
PACT_AUTH_TOKEN=replace-with-a-long-random-operator-token
PACT_ARENA_GENERATOR_SECRET=replace-with-a-long-random-arena-secret

# Required for the live agent runtime, arena quality judge and arbitration council.
OPENAI_API_KEY=replace-with-your-openai-api-key
AGENT_MODEL=gpt-5.6-terra
# Replace with the promoted ft:gpt-4o-mini... id after its golden eval passes.
ARENA_JUDGE_MODEL=gpt-4o-mini
ARENA_JUDGE_TEACHER_MODEL=gpt-5.6-terra
ARBITRATOR_MODEL=gpt-5.6-terra

PACT_ARENA_RUNNER_IMAGE=node:22-bookworm-slim
PACT_ARENA_RUNNER_TIMEOUT_MS=8000
ARENA_JUDGE_TIMEOUT_MS=20000
ARENA_JUDGE_MAX_OUTPUT_TOKENS=300
ARBITRATOR_TIMEOUT_MS=15000
PACT_RATE_LIMIT_WINDOW_MS=60000
PACT_RATE_LIMIT_MAX=120
PACT_JSON_LIMIT=64kb
PACT_EVIDENCE_MAX_CHARS=20000
PACT_HUMAN_REVIEWER_ID=authorized-human-reviewer

# Arc Testnet Platform Points. The scorer key stays server-side and must be
# authorized by PlatformPoints; never put it in VITE_* variables.
PACT_MODE=arc
PLATFORM_POINTS_ADDRESS=replace-with-platform-points-contract
PLATFORM_POINTS_AWARDER_PRIVATE_KEY=replace-with-server-side-awarder-key
PLATFORM_POINTS_CHAIN_ID=5042002
PLATFORM_POINTS_RPC_URL=https://rpc.testnet.arc.network
PLATFORM_POINTS_REQUIRED=true

# Optional real marketplace validators. Leave empty to remove these tools from
# the runtime allowlist; no simulated success is returned.
PACT_SOURCE_VERIFIER_URL=
PACT_CODE_VALIDATOR_URL=
PACT_RUNTIME_VALIDATOR_TOKEN=
PACT_RUNTIME_VALIDATOR_TIMEOUT_MS=20000
